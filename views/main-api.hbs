<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jaol System API</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Outfit:wght@100..900&display=swap" rel="stylesheet">
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&display=swap');
        
        body {
            font-family: 'Open Sans', system-ui, sans-serif;
        }
        
        .card {
            background-color: #ffffff;
            border-radius: 14px;
            box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05), 0 4px 6px -4px rgb(0 0 0 / 0.05);
            border: 1px solid #e5e7eb;
        }
        
        .status-circle {
            background: linear-gradient(135deg, #3b82f6, #1e40af);
        }
    </style>
</head>
<body class="bg-[#f8fafc] min-h-screen flex items-center justify-center p-6">
    <div class="max-w-[720px] w-full mx-auto">
        <!-- Main Card -->
        <div class="card p-10 md:p-12">
            
            <!-- HEADER -->
            <div class="flex flex-col items-center text-center mb-10">
                <div class="w-16 h-16 bg-[#1e3a8a] rounded-2xl flex items-center justify-center mb-6 shadow-inner">
                    <span class="text-white text-3xl font-bold tracking-tighter">J</span>
                </div>
                
                <h1 class="text-4xl font-semibold text-gray-900 tracking-tight">
                    Jaol System API
                </h1>
                <p class="mt-3 text-lg text-gray-600 max-w-md">
                    Enterprise REST API para la Plataforma Jaol System
                </p>
            </div>

            <!-- STATUS -->
            <div class="flex flex-col items-center text-center mb-12">
                <div class="status-circle w-24 h-24 rounded-full flex items-center justify-center mb-6 shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                </div>
                
                <div class="flex items-center gap-x-3">
                    <div class="w-3 h-3 bg-emerald-500 rounded-full animate-pulse"></div>
                    <h2 class="text-3xl font-semibold text-emerald-600">API Online</h2>
                </div>
                
                <p class="mt-2 text-lg text-gray-600">
                    Todos los servicios están operativos y listos.
                </p>
            </div>

            <!-- CLIENT INFO - NUEVA SECCIÓN -->
            <div class="mb-12">
                <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-widest mb-5 text-center">
                    Información de la Solicitud
                </h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="bg-white border border-gray-100 rounded-2xl p-6">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center text-blue-600 flex-shrink-0">
                                🌐
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="text-xs text-gray-500">IP del Cliente</div>
                                <div class="font-mono text-sm font-medium text-gray-900 break-all">
                                    {{client.ip}}
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white border border-gray-100 rounded-2xl p-6">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 bg-amber-100 rounded-xl flex items-center justify-center text-amber-600 flex-shrink-0">
                                ⏱️
                            </div>
                            <div class="flex-1">
                                <div class="text-xs text-gray-500">Tiempo de Respuesta</div>
                                <div class="font-semibold text-xl text-emerald-600">
                                    {{responseTimeMs}} <span class="text-base font-normal text-gray-500">ms</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white border border-gray-100 rounded-2xl p-6 md:col-span-2">
                        <div class="flex items-start gap-4">
                            <div class="w-10 h-10 bg-purple-100 rounded-xl flex items-center justify-center text-purple-600 flex-shrink-0 mt-0.5">
                                📱
                            </div>
                            <div class="flex-1">
                                <div class="text-xs text-gray-500 mb-1">User Agent</div>
                                <div class="text-sm text-gray-700 break-all leading-relaxed">
                                    {{client.userAgent}}
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white border border-gray-100 rounded-2xl p-6 md:col-span-2">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 bg-gray-100 rounded-xl flex items-center justify-center text-gray-600 flex-shrink-0">
                                🕒
                            </div>
                            <div>
                                <div class="text-xs text-gray-500">Fecha y Hora de la Consulta</div>
                                <div class="font-medium text-gray-900">{{timestamp}}</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- El resto de tu contenido original -->
            <!-- DESCRIPTION -->
            <div class="prose prose-gray mx-auto text-center mb-12">
                <p class="text-gray-600 leading-relaxed">
                    Bienvenido a la API REST de Jaol System.<br>
                    Esta API alimenta todo el ecosistema de la plataforma.
                </p>
            </div>

            <!-- SYSTEM INFORMATION -->
            <div class="mb-12">
                <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-widest mb-4 text-center">Información del Sistema</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <!-- ... (mantengo tus tarjetas originales) ... -->
                    <div class="flex items-center gap-4 bg-white border border-gray-100 rounded-2xl p-5">
                        <div class="w-9 h-9 bg-blue-100 rounded-xl flex items-center justify-center text-blue-600">v1</div>
                        <div>
                            <div class="text-xs text-gray-500">Versión API</div>
                            <div class="font-medium text-gray-900">v1.0.0</div>
                        </div>
                    </div>
                    
                    <!-- Puedes seguir añadiendo las demás tarjetas que ya tenías -->
                </div>
            </div>

            <!-- FOOTER -->
            <div class="pt-8 border-t border-gray-100 text-center">
                <div class="text-xs text-gray-400">
                    Jaol System — Enterprise ERP &amp; POS Platform<br>
                    © {{year}} Todos los derechos reservados.
                </div>
            </div>
        </div>
    </div>
</body>
</html>